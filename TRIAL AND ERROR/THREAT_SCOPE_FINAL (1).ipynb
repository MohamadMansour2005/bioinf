        "from collections import Counter\n",
        "\n",
        "def kmer_features(seq, k=3):\n",
        "    kmers = [seq[i:i+k] for i in range(len(seq)-k+1)]\n",
        "    count = Counter(kmers)\n",
        "\n",
        "    total = sum(count.values())\n",
        "    return {kmer: count[kmer]/total for kmer in count}"
