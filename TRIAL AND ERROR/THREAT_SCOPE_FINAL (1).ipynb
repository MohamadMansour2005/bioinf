        "\n",
        "    if prob > 0.8:\n",
        "        risk = \"HIGH DANGER\"\n",
        "        reason = \"Strong pathogen-like genetic signature detected\"\n",
        "    elif prob > 0.5:\n",
        "        risk = \"MEDIUM RISK\"\n",
        "        reason = \"Some similarity to known pathogen patterns\"\n",
        "    else:\n",
        "        risk = \"SAFE\"\n",
        "        reason = \"No strong pathogenic markers detected\"\n",
        "\n",
        "    return {\n",
