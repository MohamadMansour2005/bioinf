        "import math\n",
        "from collections import Counter\n",
        "\n",
        "def entropy(seq):\n",
        "    counts = Counter(seq)\n",
        "    total = len(seq)\n",
        "    return -sum((c/total)*math.log2(c/total) for c in counts.values())"
      ],
