    {
      "cell_type": "code",
      "source": [
        "from Bio import SeqIO\n",
        "import os\n",
        "\n",
        "BASE_PATH = \"./THREAT_SCOPE/data\"\n",
        "modes = [\"water\", \"food\", \"wound\", \"unknown\", \"safe\"]\n",
        "\n",
        "def load_sequences():\n",
        "    data = []\n",
        "\n",
        "    for mode in modes:\n",
        "        folder = os.path.join(BASE_PATH, mode)\n",
        "\n",
        "        for file in os.listdir(folder):\n",
        "            if file.endswith(\".fasta\"):\n",
        "                path = os.path.join(folder, file)\n",
        "\n",
        "                for record in SeqIO.parse(path, \"fasta\"):\n",
        "                    seq = str(record.seq)\n",
        "\n",
        "                    data.append({\n",
        "                        \"sequence\": seq,\n",
        "                        \"mode\": mode,\n",
        "                        \"label\": 1 if mode != \"safe\" else 0\n",
        "                    })\n",
        "\n",
        "    return data"
      ],
      "metadata": {
        "id": "4JqJN-Vn4zWt"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "dataset = load_sequences()\n",
        "print(\"Total sequences:\", len(dataset))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "aJMnjPsD42i7",
        "outputId": "ef7484dc-a826-497e-8461-4835b553932f"
      },
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Total sequences: 71\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "def gc_content(seq):\n",
        "    return (seq.count(\"G\") + seq.count(\"C\")) / len(seq)\n",
        "\n",
        "def entropy(seq):\n",
        "    import math\n",
        "    probs = []\n",
        "    for n in \"ATGC\":\n",
        "        p = seq.count(n) / len(seq)\n",
        "        if p > 0:\n",
        "            probs.append(p * math.log2(p))\n",
        "    return -sum(probs)\n",
        "\n",
        "from itertools import product\n",
        "\n",
        "def get_kmers(seq, k=3):\n",
        "    kmers = [''.join(p) for p in product(\"ATGC\", repeat=k)]\n",
        "    counts = dict.fromkeys(kmers, 0)\n",
        "\n",
        "    for i in range(len(seq) - k + 1):\n",
        "        kmer = seq[i:i+k]\n",
        "        if kmer in counts:\n",
        "            counts[kmer] += 1\n",
        "\n",
        "    total = sum(counts.values())\n",
        "    return [counts[k]/total if total > 0 else 0 for k in kmers]\n",
        "\n",
        "\n",
        "def extract_features(seq):\n",
        "    seq = seq[:1500]  # speed optimization\n",
        "\n",
        "    features = []\n",
        "    features.append(gc_content(seq))\n",
        "    features.append(entropy(seq))\n",
        "    features.append(len(seq))\n",
        "    features.extend(get_kmers(seq))\n",
        "\n",
        "    return features"
      ],
      "metadata": {
        "id": "LnYjktR35IH9"
      },
      "execution_count": 13,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "X = []\n",
        "y = []\n",
        "\n",
        "for item in dataset:\n",
        "    try:\n",
        "        X.append(extract_features(item[\"sequence\"]))\n",
        "        y.append(item[\"label\"])\n",
        "    except:\n",
        "        continue\n",
        "\n",
        "X = np.array(X)\n",
        "y = np.array(y)\n",
        "\n",
        "print(\"Shape:\", X.shape)"
      ],
      "metadata": {
